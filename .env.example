# ========================================
# SuiSui Book 環境變數設定
# ========================================
# 複製此檔案為 .env 並填入正確的值
# .env 檔案不應上傳到 Git

# === 必填 ===

# MongoDB 連線字串 (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/suisui-book?retryWrites=true&w=majority

# JWT 密鑰 (至少 32 字元的隨機字串)
# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# Cloudflare Tunnel Token
# 從 Cloudflare Zero Trust → Tunnels → 你的 Tunnel → Configure 取得
CLOUDFLARE_TUNNEL_TOKEN=

# === 選填 ===

# Rate Limiting (預設值已夠用)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Sentry 錯誤監控 (https://sentry.io)
SENTRY_DSN_BACKEND=
SENTRY_ENVIRONMENT=production

# LINE Login (需申請 LINE Login Channel)
# https://developers.line.biz/console/
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=https://你的網域/auth/line/callback

# Email 通知 (SMTP)
# Gmail 需使用「應用程式密碼」: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=SuiSui Book <noreply@你的網域>
