PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/beauty-booking
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Sentry
SENTRY_DSN_BACKEND=
SENTRY_ENVIRONMENT=development

# LINE Login
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=http://localhost:3000/auth/line/callback

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Cloudflare Tunnel (部署用)
CLOUDFLARE_TUNNEL_TOKEN=
